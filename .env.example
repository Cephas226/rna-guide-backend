# ============================================================
# RNA Guide Backend - Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# ============================================================

# ── Serveur ──────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:4200,http://localhost:3001

# ── Base de données (Neon PostgreSQL) ────────────────────────
# Obtenir sur: https://neon.tech
DATABASE_URL="postgresql://user:password@ep-cool-wildflower-123.eu-west-2.aws.neon.tech/rna_guide?sslmode=require"

# ── JWT Secrets (générer avec: openssl rand -base64 64) ──────
JWT_ACCESS_SECRET=rna-guide-access-secret-CHANGE-ME-IN-PRODUCTION-minimum-32-chars
JWT_REFRESH_SECRET=rna-guide-refresh-secret-CHANGE-ME-IN-PRODUCTION-minimum-32-chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# ── Supabase Storage (photos terrain) ────────────────────────
# Obtenir sur: https://supabase.com
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_BUCKET=rna-photos

# ── Upload ───────────────────────────────────────────────────
MAX_FILE_SIZE_MB=10
